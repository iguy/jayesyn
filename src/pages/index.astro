---
// jayesyn.com — homepage
// Placeholders to replace before launch are marked TODO.
const releases = [
  { code: 'SGL 001', title: 'Common Ground', date: 'TBA 2026', status: 'Announced' },
  { code: 'SGL 002', title: 'Single Two', date: 'TBA 2026', status: 'Scheduled' },
  { code: 'SGL 003', title: 'Single Three', date: 'TBA 2026', status: 'Scheduled' },
  { code: 'EP 001', title: 'Four-Track EP', date: 'TBA 2026', status: 'In production' },
  { code: 'RMX 001', title: 'Remix Project', date: 'TBA 2027', status: 'Planned' },
  { code: 'VNL 001', title: 'EP on Vinyl', date: 'TBA 2027', status: 'Planned' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: 'Jayesyn',
  url: 'https://jayesyn.com',
  genre: 'Electronic', // TODO: confirm genre with artist
  foundingLocation: {
    '@type': 'Place',
    name: 'Los Angeles, California',
  },
  member: {
    '@type': 'Person',
    name: 'Jason Thomas Nelson',
  },
  // TODO: add sameAs array once platform profiles are live:
  // sameAs: ['https://open.spotify.com/artist/...', 'https://music.apple.com/...', ...]
};
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Jayesyn — Three singles. One EP. Remixes. Vinyl.</title>
<meta name="description" content="Jayesyn is a Los Angeles artist releasing three singles, a four-track EP, a remix project, and a vinyl pressing. Hear it first — join the list." />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="canonical" href="https://jayesyn.com/" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;700;900&family=Space+Grotesk:wght@400;500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>

<header class="top">
  <span class="mark" aria-hidden="true"></span>
  <span class="top-name">JAYESYN</span>
  <a class="top-link" href="#signup">Join the list</a>
</header>

<main>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-text">
      <p class="eyebrow">Los Angeles &middot; New project</p>
      <h1>JAYESYN</h1>
      <p class="lede">
        This is a soulful and uplifting R&amp;B track with a hopeful, unifying
        message. The song is carried by a male vocalist with a smooth, honeyed,
        and exceptionally clear voice. His delivery is intimate and slightly
        breathy in the verses, drawing the listener in, before blossoming into a
        powerful, resonant, and passionate performance in the chorus. Layered
        vocal harmonies are introduced to create a rich, choir-like effect,
        amplifying the song's communal and heartfelt theme.
      </p>
      <p class="lede-detail">
        The production is clean and polished, built upon a warm blend of classic
        and modern soul instrumentation. A groovy, melodic bass guitar line locks
        in with a steady mid-tempo drum pattern, creating a relaxed yet compelling
        foundation. A gentle electric piano provides harmonic texture, while a
        standout violin plays a poignant, memorable melody in the intro and
        instrumental breaks, adding a touch of classical elegance. The overall
        atmosphere is spacious and atmospheric, with subtle synth pads and a
        generous use of reverb that allows the heartfelt vocals and soulful
        instrumentation to shine, resulting in a moving and beautifully crafted
        call for common ground.
      </p>
      <a class="cta" href="#signup">Hear the first single early</a>
    </div>

    <!-- Signature: rotating record-label disc -->
    <div class="disc-wrap" aria-hidden="true">
      <svg class="disc" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <path id="ringpath" d="M 200,200 m -152,0 a 152,152 0 1,1 304,0 a 152,152 0 1,1 -304,0" />
        </defs>
        <circle cx="200" cy="200" r="198" fill="#0D0B10" />
        <circle cx="200" cy="200" r="188" fill="none" stroke="#1D2A2E" stroke-width="1" />
        <circle cx="200" cy="200" r="172" fill="none" stroke="#1D2A2E" stroke-width="1" />
        <circle cx="200" cy="200" r="120" fill="#EFE6D8" />
        <circle cx="200" cy="200" r="119" fill="none" stroke="#121014" stroke-width="2" />
        <text class="ring-text">
          <textPath href="#ringpath" startOffset="0">
            THREE SINGLES &#183; ONE EP &#183; REMIX PROJECT &#183; VINYL &#183; ORIGINAL ARTWORK &#183;&nbsp;
          </textPath>
        </text>
        <text x="200" y="188" text-anchor="middle" class="label-name">JAYESYN</text>
        <text x="200" y="216" text-anchor="middle" class="label-sub">JSN&#8211;001 &#183; 33&#8531; RPM</text>
        <text x="200" y="238" text-anchor="middle" class="label-sub">STEREO</text>
        <circle cx="200" cy="200" r="7" fill="#121014" />
      </svg>
    </div>
  </section>

  <!-- RELEASE SEQUENCE -->
  <section class="releases" aria-labelledby="rel-h">
    <h2 id="rel-h" class="section-h">The sequence</h2>
    <ol class="rel-track">
      {releases.map((r) => (
        <li class="rel-card">
          <span class="rel-code">{r.code}</span>
          <span class="rel-title">{r.title}</span>
          <span class="rel-meta">{r.date} &middot; {r.status}</span>
        </li>
      ))}
    </ol>
  </section>

  <!-- ARTWORK -->
  <section class="art" aria-labelledby="art-h">
    <h2 id="art-h" class="section-h">The art</h2>
    <p class="art-lede">
      Every release is packaged in original visual art by the artist —
      fifty pieces, one body of work.
    </p>
    <!-- TODO: replace placeholder tiles with real artwork files -->
    <div class="art-grid" aria-hidden="true">
      {[1, 2, 3, 4, 5, 6].map((n) => (
        <div class="art-tile"><span>ART {String(n).padStart(2, '0')} / 50</span></div>
      ))}
    </div>
  </section>

  <!-- SIGNUP -->
  <section class="signup" id="signup" aria-labelledby="signup-h">
    <h2 id="signup-h">Hear it first.</h2>
    <p>One email when each release drops. Nothing else.</p>
    <form action="https://formspree.io/f/xpqvdjyb" method="post">
      <label class="visually-hidden" for="email">Email address</label>
      <input id="email" type="email" name="email" placeholder="you@example.com" required />
      <button type="submit">Join the list</button>
    </form>
  </section>
</main>

<footer class="foot">
  <p class="foot-name">JAYESYN</p>
  <p class="foot-meta">
    Los Angeles, CA &middot; Booking &amp; press:
    <a href="mailto:garycrossey@irishguy.us">garycrossey@irishguy.us</a>
  </p>
  <p class="foot-credit">
    Released via <a href="https://irishguydesign.studio" rel="noopener">Irishguy Design Studio</a>
    &middot; &copy; {new Date().getFullYear()} Jayesyn. All rights reserved.
  </p>
</footer>

<style is:global>
:root {
  --carbon: #121014;
  --carbon-deep: #0d0b10;
  --cream: #efe6d8;
  --uv: #6399bb;
  --uv-soft: #82b0cb;
  --line: #2a2333;
  --dim: #9b93a8;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--carbon);
  color: var(--cream);
  font-family: 'Space Grotesk', system-ui, sans-serif;
  font-size: 17px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

.visually-hidden {
  position: absolute; width: 1px; height: 1px;
  overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap;
}

a { color: var(--uv-soft); }
a:focus-visible, button:focus-visible, input:focus-visible {
  outline: 2px solid var(--uv-soft);
  outline-offset: 3px;
}

/* ---------- header ---------- */
.top {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 1.1rem clamp(1.25rem, 4vw, 3rem);
  border-bottom: 1px solid var(--line);
}
.mark {
  width: 18px; height: 18px; border-radius: 50%;
  border: 3px solid var(--uv);
}
.top-name {
  font-family: 'Unbounded', sans-serif;
  font-weight: 700; font-size: 0.85rem; letter-spacing: 0.18em;
}
.top-link {
  margin-left: auto;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.8rem; text-decoration: none;
  color: var(--cream); border-bottom: 1px solid var(--uv);
  padding-bottom: 2px;
}
.top-link:hover { color: var(--uv-soft); }

/* ---------- hero ---------- */
.hero {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
  align-items: center;
  gap: clamp(2rem, 5vw, 4rem);
  padding: clamp(3rem, 8vw, 6rem) clamp(1.25rem, 4vw, 3rem);
  max-width: 1200px; margin: 0 auto;
}
.eyebrow {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.8rem; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--uv-soft);
  margin-bottom: 1rem;
}
h1 {
  font-family: 'Unbounded', sans-serif;
  font-weight: 900;
  font-size: clamp(2.2rem, 8.5vw, 6.5rem);
  line-height: 0.95;
  letter-spacing: -0.01em;
  white-space: nowrap;
}
.lede {
  margin-top: 1.5rem;
  max-width: 34rem;
  color: var(--cream);
  font-size: 1.1rem;
}
.lede-detail {
  margin-top: 1.1rem;
  max-width: 34rem;
  color: var(--dim);
  font-size: 0.95rem;
}
.cta {
  display: inline-block;
  margin-top: 2rem;
  font-family: 'Unbounded', sans-serif;
  font-weight: 700; font-size: 0.85rem;
  text-decoration: none;
  background: var(--uv);
  color: var(--cream);
  padding: 0.9rem 1.6rem;
  border-radius: 999px;
  transition: background 160ms ease;
}
.cta:hover { background: var(--uv-soft); }

/* signature disc */
.disc-wrap { display: flex; justify-content: center; }
.disc {
  width: min(400px, 80vw);
  animation: spin 40s linear infinite;
  cursor: pointer;
}
.disc-wrap.playing .disc {
  animation-duration: 4s;
}
@keyframes spin { to { transform: rotate(360deg); } }
@media (prefers-reduced-motion: reduce) {
  .disc { animation: none; }
  html { scroll-behavior: auto; }
}
.ring-text {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 15px; letter-spacing: 0.28em;
  fill: var(--uv-soft);
}
.label-name {
  font-family: 'Unbounded', sans-serif;
  font-weight: 900; font-size: 34px;
  fill: var(--carbon);
}
.label-sub {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px; letter-spacing: 0.14em;
  fill: var(--carbon);
}

/* ---------- releases ---------- */
.section-h {
  font-family: 'Unbounded', sans-serif;
  font-weight: 700;
  font-size: clamp(1.4rem, 3vw, 2rem);
  margin-bottom: 1.75rem;
}
.releases {
  max-width: 1200px; margin: 0 auto;
  padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.25rem, 4vw, 3rem);
  border-top: 1px solid var(--line);
}
.rel-track {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
}
.rel-card {
  background: var(--carbon-deep);
  padding: 1.25rem 1.1rem 1.4rem;
  display: flex; flex-direction: column; gap: 0.45rem;
}
.rel-code {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.75rem; letter-spacing: 0.12em;
  color: var(--uv-soft);
}
.rel-title { font-weight: 500; }
.rel-meta {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.72rem; color: var(--dim);
}

/* ---------- art ---------- */
.art {
  max-width: 1200px; margin: 0 auto;
  padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.25rem, 4vw, 3rem);
  border-top: 1px solid var(--line);
}
.art-lede { color: var(--dim); max-width: 36rem; margin-bottom: 1.75rem; }
.art-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 0.75rem;
}
.art-tile {
  aspect-ratio: 1;
  border: 1px solid var(--line);
  background:
    radial-gradient(circle at 30% 30%, rgba(99, 153, 187, 0.18), transparent 60%),
    var(--carbon-deep);
  display: flex; align-items: flex-end;
  padding: 0.75rem;
}
.art-tile span {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.7rem; color: var(--dim); letter-spacing: 0.1em;
}

/* ---------- signup ---------- */
.signup {
  max-width: 720px; margin: 0 auto;
  padding: clamp(3rem, 8vw, 5.5rem) clamp(1.25rem, 4vw, 3rem);
  text-align: center;
}
.signup h2 {
  font-family: 'Unbounded', sans-serif;
  font-weight: 900;
  font-size: clamp(1.8rem, 5vw, 3rem);
}
.signup p { color: var(--dim); margin-top: 0.75rem; }
.signup form {
  margin-top: 2rem;
  display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap;
}
.signup input[type='email'] {
  flex: 1 1 260px; max-width: 340px;
  background: var(--carbon-deep);
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--cream);
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1rem;
  padding: 0.85rem 1.25rem;
}
.signup input::placeholder { color: var(--dim); }
.signup button {
  font-family: 'Unbounded', sans-serif;
  font-weight: 700; font-size: 0.85rem;
  background: var(--uv); color: var(--cream);
  border: 0; border-radius: 999px;
  padding: 0.85rem 1.5rem;
  cursor: pointer;
  transition: background 160ms ease;
}
.signup button:hover { background: var(--uv-soft); }
.hp { position: absolute; left: -5000px; }

/* ---------- footer ---------- */
.foot {
  border-top: 1px solid var(--line);
  padding: 2.5rem clamp(1.25rem, 4vw, 3rem) 3rem;
  text-align: center;
}
.foot-name {
  font-family: 'Unbounded', sans-serif;
  font-weight: 700; font-size: 0.9rem; letter-spacing: 0.2em;
}
.foot-meta { margin-top: 0.75rem; font-size: 0.9rem; color: var(--dim); }
.foot-credit {
  margin-top: 0.5rem;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.75rem; color: var(--dim);
}

/* ---------- responsive ---------- */
@media (max-width: 820px) {
  .hero { grid-template-columns: 1fr; }
  .disc-wrap { order: -1; }
  .disc { width: min(300px, 70vw); }
}
</style>

<audio id="record-audio" src="/common-ground-sample.m4a" preload="auto" loop></audio>

<script>
  const audio = document.getElementById('record-audio');
  const discWrap = document.querySelector('.disc-wrap');
  const cta = document.querySelector('.cta');

  function startPlayback() {
    audio.play().catch(() => {
      // Blocked until the visitor's first click/tap on the page (browser autoplay policy)
    });
    discWrap.classList.add('playing');
  }

  function stopPlayback() {
    audio.pause();
    discWrap.classList.remove('playing');
  }

  // Hover the record: play while hovering, pause on leave
  discWrap.addEventListener('mouseenter', startPlayback);
  discWrap.addEventListener('mouseleave', stopPlayback);

  // Click/tap the record: toggle (also the mobile path, since phones have no hover)
  discWrap.addEventListener('click', () => {
    audio.paused ? startPlayback() : stopPlayback();
  });

  // Hover the "Hear the first single early" button: same behavior
  cta.addEventListener('mouseenter', startPlayback);
  cta.addEventListener('mouseleave', stopPlayback);
  // Clicking the CTA still scrolls to #signup as before — no preventDefault —
  // and that click doubles as the gesture that unlocks audio in the browser.
  cta.addEventListener('click', startPlayback);
</script>

</body>
</html>