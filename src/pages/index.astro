---
// index.astro - Jayesyn | Common Ground (FULL MASTER ARCHITECTURE RESTORED)
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Jayesyn | Common Ground</title>
    
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">

    <style is:global>
      body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #0c0c0e;
      }
      .font-serif {
        font-family: 'Playfair Display', serif;
      }
      @keyframes spin-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .animate-vinyl {
        animation: spin-slow 8s linear infinite;
      }
    </style>
  </head>
  
  <body class="text-zinc-100 bg-[#0c0c0e] min-h-screen tracking-tight antialiased selection:bg-[#6399bb]/30">
    
    <!-- Background Texture/Glow -->
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
      <div class="absolute -top-[40%] -left-[20%] w-[80%] h-[80%] rounded-full bg-[#6399bb]/5 blur-[120px]"></div>
      <div class="absolute -bottom-[40%] -right-[20%] w-[80%] h-[80%] rounded-full bg-zinc-900/40 blur-[120px]"></div>
    </div>

    <!-- Header Navigation -->
    <header class="relative z-10 w-full max-w-7xl mx-auto px-6 py-8 flex justify-between items-center">
      <div class="text-xl font-light tracking-[0.3em] text-white">JAYESYN</div>
      <nav class="hidden md:flex items-center gap-8 text-xs tracking-widest uppercase text-zinc-400">
        <a href="#concept" class="hover:text-white transition-colors">Concept</a>
        <a href="#timeline" class="hover:text-white transition-colors">Roadmap</a>
      </nav>
      <a href="#signup" class="text-xs tracking-widest uppercase bg-[#6399bb]/10 hover:bg-[#6399bb]/20 border border-[#6399bb]/30 text-[#6399bb] px-6 py-3 rounded-full transition-all duration-300 backdrop-blur-sm">
        Access Portal
      </a>
    </header>

    <main class="relative z-10 max-w-7xl mx-auto px-6 pt-12 pb-32 space-y-48">
      
      <!-- HERO AREA: Concept & Vinyl Player -->
      <section id="concept" class="grid lg:grid-cols-12 gap-16 items-center pt-8">
        
        <!-- Left Side: Cinematic Presentation -->
        <div class="lg:col-span-7 space-y-10 order-2 lg:order-1">
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <span class="h-[1px] w-8 bg-[#6399bb]"></span>
              <span class="text-xs uppercase tracking-[0.4em] text-[#6399bb] font-semibold">Debut Spatial Architecture</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-light tracking-tight text-white leading-[1.1] font-serif">
              Common <br /><span class="font-normal italic text-zinc-400">Ground</span>
            </h1>
          </div>
          
          <div class="space-y-6 text-zinc-400 font-light leading-relaxed text-base md:text-lg max-w-xl">
            <p>
              An immersive, artist-led R&B project designed to explore shared sonic spaces. Built on warm electric piano foundations, a locked groove, and an expansive trumpet motif bridging late-night jazz architecture with modern rhythmic depth.
            </p>
            <p class="text-sm text-zinc-500">
              Hover or touch the visual press to spin the record and audition the early conceptual master sequence.
            </p>
          </div>
        </div>

        <!-- Right Side: High-Fidelity Vinyl Experience -->
        <div class="lg:col-span-5 flex flex-col items-center justify-center order-1 lg:order-2">
          <div id="interactive-player" class="relative w-72 h-72 md:w-[400px] md:h-[400px] group cursor-pointer">
            
            <!-- Vinyl Sleeve / Outer Shadow Jacket -->
            <div class="absolute inset-0 bg-gradient-to-tr from-zinc-950 to-zinc-900 rounded-2xl shadow-[0_30px_70px_rgba(0,0,0,0.9)] border border-zinc-800/40 z-20 transition-transform duration-500 group-hover:-translate-x-6 flex items-center justify-center overflow-hidden">
              <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-zinc-800/10 via-transparent to-transparent"></div>
              <div class="text-center p-6 space-y-2">
                <p class="text-[10px] tracking-[0.3em] uppercase text-zinc-500">Jayesyn</p>
                <h2 class="font-serif text-2xl font-light text-zinc-300 italic tracking-wide">Common Ground</h2>
                <p class="text-[9px] tracking-widest uppercase text-[#6399bb]/70 pt-4">Stereo LP &bull; Preview Edition</p>
              </div>
            </div>

            <!-- Heavy Weight Vinyl Disc -->
            <div 
              id="vinyl-disc" 
              class="absolute inset-2 rounded-full bg-gradient-to-b from-[#111113] to-[#070708] shadow-[0_15px_40px_rgba(0,0,0,0.8)] transition-transform duration-700 ease-out z-10 group-hover:translate-x-32 flex items-center justify-center border border-black"
            >
              <!-- Micro Grooves -->
              <div class="absolute inset-4 rounded-full border border-zinc-900/60 opacity-60"></div>
              <div class="absolute inset-8 rounded-full border border-black/80"></div>
              <div class="absolute inset-14 rounded-full border border-zinc-800/20"></div>
              <div class="absolute inset-20 rounded-full border border-black/40"></div>
              <div class="absolute inset-28 rounded-full border border-zinc-900/40"></div>
              
              <!-- Center Core Label -->
              <div class="w-28 h-28 md:w-36 md:h-36 rounded-full bg-zinc-900 border-[5px] border-[#0c0c0e] shadow-[inset_0_4px_10px_rgba(0,0,0,0.9)] flex items-center justify-center overflow-hidden relative">
                <div class="absolute inset-0 bg-gradient-to-br from-zinc-950 via-[#6399bb]/10 to-zinc-900 flex flex-col items-center justify-center text-center p-4">
                  <span class="text-[9px] tracking-[0.25em] font-medium text-white/80 uppercase">Jayesyn</span>
                  <span class="text-[8px] text-[#6399bb] italic tracking-wider mt-0.5">Common Ground</span>
                </div>
                <!-- Center Spindle Pin Hole -->
                <div class="w-3 h-3 rounded-full bg-[#0c0c0e] z-30 border border-zinc-800/80 shadow-inner"></div>
              </div>
            </div>

          </div>

          <!-- UI Indicator Badge -->
          <div id="playback-badge" class="mt-8 flex items-center gap-3 bg-zinc-900/60 border border-zinc-800/80 px-5 py-2.5 rounded-full text-xs text-zinc-400 tracking-widest uppercase backdrop-blur-sm transition-colors duration-300">
            <span class="relative flex h-2 w-2">
              <span id="badge-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-zinc-600 opacity-75"></span>
              <span id="badge-dot" class="relative inline-flex rounded-full h-2 w-2 bg-zinc-600"></span>
            </span>
            <span id="badge-text">Deck Idle</span>
          </div>
        </div>
      </section>

      <!-- TIMELINE / MULTI-RELEASE PROJECT SCOPE -->
      <section id="timeline" class="border-t border-zinc-900/60 pt-24 max-w-4xl mx-auto space-y-16">
        <div class="space-y-2">
          <span class="text-xs uppercase tracking-[0.3em] text-[#6399bb] font-semibold block">Strategic Roadmap</span>
          <h2 class="text-3xl md:text-4xl font-light text-white font-serif">The Master Project Scope</h2>
        </div>

        <div class="relative border-l border-zinc-800/60 ml-4 md:ml-32 space-y-16">
          <!-- Phase 1: The 3 Singles Campaign -->
          <div class="relative pl-8 group">
            <div class="absolute -left-[5px] top-2 w-2.5 h-2.5 rounded-full bg-[#6399bb] ring-4 ring-[#0c0c0e]"></div>
            <div class="text-[11px] font-mono tracking-widest text-[#6399bb] uppercase">Phase 01 / Campaign Launch</div>
            <h3 class="text-lg font-medium text-white mt-1">The 3-Single Narrative Sequence</h3>
            <p class="text-zinc-400 font-light mt-2 text-sm md:text-base leading-relaxed">
              Initiating the campaign with a trilogy of interconnected singles, led by <span class="text-white italic">"Common Ground"</span>. Each drop serves as a distinct sonic and visual chapter building the atmospheric foundation of the project.
            </p>
          </div>

          <!-- Phase 2: The EP Drop -->
          <div class="relative pl-8 group">
            <div class="absolute -left-[5px] top-2 w-2.5 h-2.5 rounded-full bg-zinc-800 ring-4 ring-[#0c0c0e]"></div>
            <div class="text-[11px] font-mono tracking-widest text-zinc-500 uppercase">Phase 02 / Full Experience</div>
            <h3 class="text-lg font-medium text-white mt-1">Debut EP Studio Release</h3>
            <p class="text-zinc-400 font-light mt-2 text-sm md:text-base leading-relaxed">
              The culmination of the singles into a cohesive, long-form digital EP across all streaming platforms. Expands the record's late-night jazz architecture with unreleased B-sides and deeper ambient movements.
            </p>
          </div>

          <!-- Phase 3: The Remix Vinyl -->
          <div class="relative pl-8 group">
            <div class="absolute -left-[5px] top-2 w-2.5 h-2.5 rounded-full bg-zinc-800 ring-4 ring-[#0c0c0e]"></div>
            <div class="text-[11px] font-mono tracking-widest text-zinc-500 uppercase">Phase 03 / Physical Artifact</div>
            <h3 class="text-lg font-medium text-white mt-1">Remix Vinyl Project & Pressing</h3>
            <p class="text-zinc-400 font-light mt-2 text-sm md:text-base leading-relaxed">
              Transitioning the EP into a physical, heavyweight remix vinyl project. Featuring elite club reworks, alternative jazz arrangements, and premium tactile packaging available strictly for private inner-circle pre-orders.
            </p>
          </div>
        </div>
      </section>

      <!-- EMAIL MARKETING ENGINE -->
      <section id="signup" class="bg-gradient-to-b from-zinc-900/40 to-zinc-950/60 border border-zinc-900/80 rounded-2xl p-8 md:p-16 max-w-4xl mx-auto text-center space-y-8 shadow-2xl relative">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/3 h-[1px] bg-gradient-to-r from-transparent via-[#6399bb]/40 to-transparent"></div>
        
        <div class="max-w-xl mx-auto space-y-3">
          <h2 class="text-3xl font-light text-white font-serif">Enter the Architecture</h2>
          <p class="text-xs md:text-sm text-zinc-400 font-light tracking-wide leading-relaxed">
            Register your credentials to claim placement priority for upcoming physical vinyl pressings and exclusive text alerts.
          </p>
        </div>

        <form class="max-w-md mx-auto flex flex-col sm:flex-row gap-3 pt-4" onsubmit="event.preventDefault(); alert('Transmission linked.');">
          <input 
            type="email" 
            required 
            placeholder="Enter your email address" 
            class="flex-1 bg-zinc-950/60 border border-zinc-800/80 rounded-xl px-5 py-3.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-[#6399bb] transition-all duration-300"
          />
          <button 
            type="submit" 
            class="bg-[#6399bb] hover:bg-[#5387a8] text-white font-medium text-xs tracking-widest uppercase px-8 py-4 rounded-xl transition-all duration-300 shadow-md"
          >
            Join Network
          </button>
        </form>
        <span class="text-[10px] tracking-[0.25em] text-zinc-600 uppercase block">Curated Pipeline &bull; Zero Spam Architecture</span>
      </section>

    </main>

    <footer class="w-full text-center py-12 border-t border-zinc-950 text-[10px] text-zinc-600 tracking-[0.25em] uppercase relative z-10">
      &copy; 2026 JAYESYN. ALL RIGHTS RESERVED. ARCHITECTED FOR COMMON GROUND.
    </footer>

    <audio id="audio-deck" src="/common-ground-sample.m4a" preload="auto" loop></audio>

    <script>
      const player = document.getElementById('interactive-player');
      const disc = document.getElementById('vinyl-disc');
      const audio = document.getElementById('audio-deck') as HTMLAudioElement;
      
      const bText = document.getElementById('badge-text');
      const bPulse = document.getElementById('badge-pulse');
      const bDot = document.getElementById('badge-dot');

      if (player && disc && audio) {
        player.addEventListener('mouseenter', () => {
          audio.play().catch(e => console.log('Context block handled:', e));
          disc.classList.add('animate-vinyl');
          
          if (bText && bPulse && bDot) {
            bText.innerText = "Auditioning Loop";
            bText.classList.add('text-[#6399bb]');
            bDot.classList.replace('bg-zinc-600', 'bg-[#6399bb]');
            bPulse.classList.replace('bg-zinc-600', 'bg-[#6399bb]');
          }
        });

        player.addEventListener('mouseleave', () => {
          audio.pause();
          disc.classList.remove('animate-vinyl');
          
          if (bText && bPulse && bDot) {
            bText.innerText = "Deck Idle";
            bText.classList.remove('text-[#6399bb]');
            bDot.classList.replace('bg-[#6399bb]', 'bg-zinc-600');
            bPulse.classList.replace('bg-[#6399bb]', 'bg-zinc-600');
          }
        });
      }
    </script>
  </body>
</html>