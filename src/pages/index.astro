<style is:global>
:root {
  --carbon: #121014;
  --carbon-deep: #0d0b10;
  --cream: #efe6d8;
  --uv: #6399bb;               /* Updated: Primary Brand Blue */
  --uv-soft: #84b6d6;          /* Updated: Softer Highlight Blue */
  --line: #2a2333;
  --dim: #9b93a8;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--carbon);
  color: var(--cream);
  font-family: 'Space Grotesk', system-ui, sans-serif;
  font-size: 17px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

.visually-hidden {
  position: absolute; width: 1px; height: 1px;
  overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap;
}

a { color: var(--uv-soft); }
a:focus-visible, button:focus-visible, input:focus-visible {
  outline: 2px solid var(--uv-soft);
  outline-offset: 3px;
}

/* ---------- header ---------- */
.top {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 1.1rem clamp(1.25rem, 4vw, 3rem);
  border-bottom: 1px solid var(--line);
}
.mark {
  width: 18px; height: 18px; border-radius: 50%;
  border: 3px solid var(--uv);
}
.top-name {
  font-family: 'Unbounded', sans-serif;
  font-weight: 700; font-size: 0.85rem; letter-spacing: 0.18em;
}
.top-link {
  margin-left: auto;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.8rem; text-decoration: none;
  color: var(--cream); border-bottom: 1px solid var(--uv);
  padding-bottom: 2px;
}
.top-link:hover { color: var(--uv-soft); }

/* ---------- hero ---------- */
.hero {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
  align-items: center;
  gap: clamp(2rem, 5vw, 4rem);
  padding: clamp(3rem, 8vw, 6rem) clamp(1.25rem, 4vw, 3rem);
  max-width: 1200px; margin: 0 auto;
}
.eyebrow {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.8rem; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--uv-soft);
  margin-bottom: 1rem;
}
h1 {
  font-family: 'Unbounded', sans-serif;
  font-weight: 900;
  font-size: clamp(3.2rem, 9vw, 6.5rem);
  line-height: 0.95;
  letter-spacing: -0.01em;
}
.lede {
  margin-top: 1.5rem;
  max-width: 34rem;
  color: var(--dim);
  font-size: 1.1rem;
}
.cta {
  display: inline-block;
  margin-top: 2rem;
  font-family: 'Unbounded', sans-serif;
  font-weight: 700; font-size: 0.85rem;
  text-decoration: none;
  color: var(--carbon-deep);
  background: var(--uv);
  color: var(--cream);
  padding: 0.9rem 1.6rem;
  border-radius: 999px;
  transition: background 160ms ease;
}
.cta:hover { background: var(--uv-soft); }

/* signature disc */
.disc-wrap { display: flex; justify-content: center; }
.disc {
  width: min(400px, 80vw);
  animation: spin 40s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
@media (prefers-reduced-motion: reduce) {
  .disc { animation: none; }
  html { scroll-behavior: auto; }
}
.ring-text {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 15px; letter-spacing: 0.28em;
  fill: var(--uv-soft);
}
.label-name {
  font-family: 'Unbounded', sans-serif;
  font-weight: 900; font-size: 34px;
  fill: var(--carbon);
}
.label-sub {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px; letter-spacing: 0.14em;
  fill: var(--carbon);
}

/* ---------- releases ---------- */
.section-h {
  font-family: 'Unbounded', sans-serif;
  font-weight: 700;
  font-size: clamp(1.4rem, 3vw, 2rem);
  margin-bottom: 1.75rem;
}
.releases {
  max-width: 1200px; margin: 0 auto;
  padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.25rem, 4vw, 3rem);
  border-top: 1px solid var(--line);
}
.rel-track {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
}
.rel-card {
  background: var(--carbon-deep);
  padding: 1.25rem 1.1rem 1.4rem;
  display: flex; flex-direction: column; gap: 0.45rem;
}
.rel-code {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.75rem; letter-spacing: 0.12em;
  color: var(--uv-soft);
}
.rel-title { font-weight: 500; }
.rel-meta {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.72rem; color: var(--dim);
}

/* ---------- art ---------- */
.art {
  max-width: 1200px; margin: 0 auto;
  padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.25rem, 4vw, 3rem);
  border-top: 1px solid var(--line);
}
.art-lede { color: var(--dim); max-width: 36rem; margin-bottom: 1.75rem; }
.art-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 0.75rem;
}
.art-tile {
  aspect-ratio: 1;
  border: 1px solid var(--line);
  background:
    radial-gradient(circle at 30% 30%, rgba(99, 153, 187, 0.18), transparent 60%), /* Updated: Changed to match brand blue */
    var(--carbon-deep);
  display: flex; align-items: flex-end;
  padding: 0.75rem;
}
.art-tile span {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.7rem; color: var(--dim); letter-spacing: 0.1em;
}

/* ---------- signup ---------- */
.signup {
  max-width: 720px; margin: 0 auto;
  padding: clamp(3rem, 8vw, 5.5rem) clamp(1.25rem, 4vw, 3rem);
  text-align: center;
}
.signup h2 {
  font-family: 'Unbounded', sans-serif;
  font-weight: 900;
  font-size: clamp(1.8rem, 5vw, 3rem);
}
.signup p { color: var(--dim); margin-top: 0.75rem; }
.signup form {
  margin-top: 2rem;
  display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap;
}
.signup input[type='email'] {
  flex: 1 1 260px; max-width: 340px;
  background: var(--carbon-deep);
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--cream);
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1rem;
  padding: 0.85rem 1.25rem;
}
.signup input::placeholder { color: var(--dim); }
.signup button {
  font-family: 'Unbounded', sans-serif;
  font-weight: 700; font-size: 0.85rem;
  background: var(--uv); color: var(--cream);
  border: 0; border-radius: 999px;
  padding: 0.85rem 1.5rem;
  cursor: pointer;
  transition: background 160ms ease;
}
.signup button:hover { background: var(--uv-soft); }
.hp { position: absolute; left: -5000px; }

/* ---------- footer ---------- */
.foot {
  border-top: 1px solid var(--line);
  padding: 2.5rem clamp(1.25rem, 4vw, 3rem) 3rem;
  text-align: center;
}
.foot-name {
  font-family: 'Unbounded', sans-serif;
  font-weight: 700; font-size: 0.9rem; letter-spacing: 0.2em;
}
.foot-meta { margin-top: 0.75rem; font-size: 0.9rem; color: var(--dim); }
.foot-credit {
  margin-top: 0.5rem;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.75rem; color: var(--dim);
}

/* ---------- responsive ---------- */
@media (max-width: 820px) {
  .hero { grid-template-columns: 1fr; }
  .disc-wrap { order: -1; }
  .disc { width: min(300px, 70vw); }
}
</style>