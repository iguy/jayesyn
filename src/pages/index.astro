---
// index.astro - Jayesyn Artist Website & Rollout Plan
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Jayesyn | Common Ground</title>
    
    <!-- Tailwind CSS Play CDN Script Engine -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      // Defining your brand styling token config so Tailwind can parse the custom blue globally
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                blue: '#2563eb',     // Core Brand Blue
                blueHover: '#1d4ed8' // Darker Blue variant for interactions
              }
            }
          }
        }
      }
    </script>
    
    <!-- Google Fonts: Plus Jakarta Sans & Playfair Display -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#121212] text-[#f5f5f7] min-h-screen font-['Plus_Jakarta_Sans',sans-serif] overflow-x-hidden selection:bg-brand-blue selection:text-white">
    
    <!-- HERO SECTION: Artist Info & Interactive Vinyl -->
    <header class="max-w-6xl w-full mx-auto px-6 py-12 md:py-24 grid md:grid-cols-2 gap-12 items-center min-h-[80vh]">
      
      <!-- Left Column: Artist Bio Text -->
      <div class="space-y-6 order-2 md:order-1 max-w-xl">
        <span class="text-sm uppercase tracking-widest text-brand-blue font-semibold block">Debut Single</span>
        
        <!-- Main Artist Title with Playfair Display Font -->
        <h1 class="text-5xl md:text-7xl font-light tracking-tight text-white leading-none font-['Playfair_Display',serif]">
          Common <span class="font-normal italic text-zinc-400">Ground</span>
        </h1>
        
        <div class="h-px w-20 bg-brand-blue/60 my-4"></div>
        
        <p class="text-lg md:text-xl text-zinc-400 font-light leading-relaxed">
          Jayesyn crafts an immersive, artist-led R&B experience designed to unite listeners through a shared sonic atmosphere. 
        </p>
        
        <p class="text-base text-zinc-500 font-light leading-relaxed">
          Built on a foundation of warm electric piano chords and a locked-in bass and drum groove, the track breathes with organic textures—anchored by a soulful, sweeping trumpet melody that bridges the gap between classic soul and modern rhythm.
        </p>

        <div class="pt-4">
          <a href="#signup" class="inline-block bg-brand-blue text-white font-medium tracking-wide text-sm px-8 py-3 rounded-full hover:bg-brand-blueHover transition-colors duration-300 shadow-lg shadow-brand-blue/20">
            Join the Inner Circle
          </a>
        </div>
      </div>

      <!-- Right Column: Interactive Vinyl Record & CTA -->
      <div class="flex flex-col items-center justify-center order-1 md:order-2 group/hero select-none">
        <div class="relative w-72 h-72 md:w-96 md:h-96 flex items-center justify-center">
          
          <!-- Outer Vinyl Record -->
          <div 
            id="vinyl-record" 
            class="absolute inset-0 rounded-full bg-[#1a1a1a] shadow-[0_0_50px_rgba(0,0,0,0.8),inset_0_0_20px_rgba(255,255,255,0.05)] cursor-pointer transition-transform duration-500 ease-out group-hover/hero:scale-105 active:scale-95 flex items-center justify-center z-10"
            style="transform-origin: center center;"
          >
            <!-- Grooves detailing on the vinyl -->
            <div class="absolute inset-4 rounded-full border border-zinc-800/40"></div>
            <div class="absolute inset-10 rounded-full border border-zinc-800/30"></div>
            <div class="absolute inset-16 rounded-full border border-zinc-800/20"></div>
            <div class="absolute inset-24 rounded-full border border-zinc-800/10"></div>
            
            <!-- Center Custom Record Label Cover Art -->
            <div class="w-28 h-28 md:w-36 md:h-36 rounded-full bg-zinc-800 border-4 border-[#121212] overflow-hidden shadow-inner flex items-center justify-center relative">
              <div class="absolute inset-0 bg-gradient-to-tr from-zinc-900 via-brand-blue/20 to-zinc-700 flex flex-col items-center justify-center text-center p-2">
                <!-- Vinyl Label Artist with Playfair Display Font -->
                <span class="text-[11px] md:text-[13px] uppercase tracking-wider font-semibold text-white font-['Playfair_Display',serif]">Jayesyn</span>
                <span class="text-[8px] md:text-[10px] text-zinc-400 italic mt-0.5">Common Ground</span>
              </div>
              <!-- Center Spindle Hole -->
              <div class="w-3 h-3 rounded-full bg-[#121212] z-20 shadow-inner"></div>
            </div>
          </div>
          
        </div>

        <!-- Dynamic CTA Instruction Box -->
        <div id="cta-badge" class="mt-8 flex items-center gap-2 bg-zinc-900/80 border border-zinc-800 px-4 py-2 rounded-full backdrop-blur-sm text-sm text-zinc-400 tracking-wide transition-all duration-300 animate-pulse group-hover/hero:opacity-0 group-hover/hero:translate-y-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-blue animate-bounce"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
          <span>Roll over to play snippet</span>
        </div>
      </div>

    </header>

    <!-- MIDDLE SECTION: Marketing Plan & Rollout Timeline -->
    <section class="max-w-6xl w-full mx-auto px-6 py-20 border-t border-zinc-800/60">
      <div class="max-w-3xl">
        <span class="text-sm uppercase tracking-widest text-brand-blue font-semibold block mb-2">The Strategy</span>
        <h2 class="text-3xl md:text-5xl font-light text-white tracking-tight font-['Playfair_Display',serif] mb-12">
          Rollout <span class="italic text-zinc-400">Timeline</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Phase 1 -->
        <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-2xl p-6 hover:border-brand-blue/40 transition-all duration-300 group">
          <div class="text-xs font-semibold tracking-wider text-brand-blue uppercase mb-4 transition-colors group-hover:text-white">Phase 01 / Tease</div>
          <h3 class="text-xl font-medium text-white mb-3">Sonic Atmospheres</h3>
          <p class="text-sm text-zinc-400 font-light leading-relaxed">
            Dropping loops of the signature sweeping trumpet melodies and warm Rhodes chords across TikTok and Reels. Creating a visual language of warm, late-night organic studio textures.
          </p>
        </div>

        <!-- Phase 2 -->
        <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-2xl p-6 hover:border-brand-blue/40 transition-all duration-300 group">
          <div class="text-xs font-semibold tracking-wider text-brand-blue uppercase mb-4 transition-colors group-hover:text-white">Phase 02 / Connect</div>
          <h3 class="text-xl font-medium text-white mb-3">The Common Ground</h3>
          <p class="text-sm text-zinc-400 font-light leading-relaxed">
            Launching the digital listening experience. Fans who pre-save or join the inner circle receive early access to premium vinyl pre-orders and behind-the-scenes recording breakdown videos.
          </p>
        </div>

        <!-- Phase 3 -->
        <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-2xl p-6 hover:border-brand-blue/40 transition-all duration-300 group">
          <div class="text-xs font-semibold tracking-wider text-brand-blue uppercase mb-4 transition-colors group-hover:text-white">Phase 03 / Arrive</div>
          <h3 class="text-xl font-medium text-white mb-3">Global Release</h3>
          <p class="text-sm text-zinc-400 font-light leading-relaxed">
            Full streaming release alongside a cinematic live session video performance. Editorial playlist pushing focused on contemporary R&B, late-night grooves, and modern neo-soul lanes.
          </p>
        </div>
      </div>
    </section>

    <!-- FOOTER SECTION: Dynamic Sign-Up Form -->
    <section id="signup" class="max-w-6xl w-full mx-auto px-6 py-20 border-t border-zinc-800/60 text-center flex flex-col items-center justify-center">
      <div class="max-w-xl space-y-4 mb-8">
        <h2 class="text-3xl md:text-4xl font-light text-white tracking-tight font-['Playfair_Display',serif]">
          Step into <span class="italic text-zinc-400">Common Ground</span>
        </h2>
        <p class="text-sm text-zinc-500 font-light leading-relaxed">
          Be the first to know when the full record drops. Subscribers receive exclusive access to early listening sessions, vinyl pressings, and secret tour dates.
        </p>
      </div>

      <!-- Email Subscription Form Container -->
      <form class="w-full max-w-md flex flex-col sm:flex-row gap-3" onsubmit="event.preventDefault(); alert('Welcome to the inner circle.');">
        <input 
          type="email" 
          placeholder="Enter your email address" 
          required
          class="w-full px-5 py-3 rounded-full bg-zinc-900 border border-zinc-800 text-white placeholder-zinc-500 text-sm focus:outline-none focus:border-brand-blue transition-colors duration-300"
        />
        <button 
          type="submit" 
          class="w-full sm:w-auto bg-brand-blue text-white font-semibold text-sm px-6 py-3 rounded-full hover:bg-brand-blueHover transition-colors duration-300 whitespace-nowrap shadow-md shadow-brand-blue/10"
        >
          Subscribe
        </button>
      </form>
      
      <p class="text-[11px] text-zinc-600 font-light mt-4">No spam. Just pure music updates. Unsubscribe anytime.</p>
    </section>

    <!-- Hidden HTML5 Audio Element -->
    <audio id="audio-preview" src="/common-ground-sample.m4a" preload="auto" loop></audio>

    <!-- Custom CSS Animation Injection -->
    <style is:global>
      @keyframes record-spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .spinning {
        animation: record-spin 3.5s linear infinite !important;
      }
    </style>

    <!-- Script Handling Audio & CSS Spinning Triggers -->
    <script>
      const record = document.getElementById('vinyl-record');
      const audio = document.getElementById('audio-preview') as HTMLAudioElement;

      if (record && audio) {
        // Hover Interaction: Play & Spin
        record.addEventListener('mouseenter', () => {
          audio.play().catch(err => console.log("Audio playback safely managed:", err));
          record.classList.add('spinning');
        });

        // Leave Interaction: Pause & Halt Spin
        record.addEventListener('mouseleave', () => {
          audio.pause();
          record.classList.remove('spinning');
        });
      }
    </script>
  </body>
</html>