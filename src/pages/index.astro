---
// index.astro - Jayesyn Artist Website (Restored Working Audio Version)
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Jayesyn | Common Ground</title>
    
    <!-- Tailwind CSS Engine Fix -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts for sleek typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#121212] text-[#f5f5f7] min-h-screen flex items-center justify-center font-['Plus_Jakarta_Sans',sans-serif] overflow-x-hidden">
    
    <main class="max-w-6xl w-full mx-auto px-6 py-12 md:py-24 grid md:grid-cols-2 gap-12 items-center">
      
      <!-- Left Column: Artist Bio Text -->
      <div class="space-y-6 order-2 md:order-1 max-w-xl">
        <span class="text-sm uppercase tracking-widest text-[#6399bb] font-medium block">Debut Single</span>
        <h1 class="text-5xl md:text-7xl font-light tracking-tight text-white leading-none">
          Common <span class="font-normal italic text-zinc-400">Ground</span>
        </h1>
        
        <div class="h-px w-20 bg-[#6399bb] my-4"></div>
        
        <p class="text-lg md:text-xl text-zinc-400 font-light leading-relaxed">
          Jayesyn crafts an immersive, artist-led R&B experience designed to unite listeners through a shared sonic atmosphere. 
        </p>
        
        <p class="text-base text-zinc-500 font-light leading-relaxed">
          Built on a foundation of warm electric piano chords and a locked-in bass and drum groove, the track breathes with organic textures—anchored by a soulful, sweeping trumpet melody that bridges the gap between classic soul and modern rhythm.
        </p>
      </div>

      <!-- Right Column: Interactive Vinyl Record & CTA Container -->
      <div id="interactive-container" class="flex flex-col items-center justify-center order-1 md:order-2 group/hero select-none cursor-pointer">
        <div class="relative w-72 h-72 md:w-96 md:h-96 flex items-center justify-center">
          
          <!-- Outer Vinyl Record -->
          <div 
            id="vinyl-record" 
            class="absolute inset-0 rounded-full bg-[#1a1a1a] shadow-[0_0_50px_rgba(0,0,0,0.8),inset_0_0_20px_rgba(255,255,255,0.05)] transition-transform duration-500 ease-out group-hover/hero:scale-105 active:scale-95 flex items-center justify-center z-10"
            style="transform-origin: center center;"
          >
            <!-- Grooves detailing on the vinyl -->
            <div class="absolute inset-4 rounded-full border border-zinc-800/40"></div>
            <div class="absolute inset-10 rounded-full border border-zinc-800/30"></div>
            <div class="absolute inset-16 rounded-full border border-zinc-800/20"></div>
            <div class="absolute inset-24 rounded-full border border-zinc-800/10"></div>
            
            <!-- Center Custom Record Label Cover Art -->
            <div class="w-28 h-28 md:w-36 md:h-36 rounded-full bg-zinc-800 border-4 border-[#121212] overflow-hidden shadow-inner flex items-center justify-center relative">
              <div class="absolute inset-0 bg-gradient-to-tr from-zinc-900 via-[#6399bb]/20 to-zinc-700 flex flex-col items-center justify-center text-center p-2">
                <span class="text-[9px] md:text-[11px] uppercase tracking-wider font-semibold text-white">Jayesyn</span>
                <span class="text-[8px] md:text-[10px] text-zinc-400 italic">Common Ground</span>
              </div>
              <!-- Center Spindle Hole -->
              <div class="w-3 h-3 rounded-full bg-[#121212] z-20 shadow-inner"></div>
            </div>
          </div>
          
        </div>

        <!-- Dynamic CTA Instruction Box -->
        <div id="cta-badge" class="mt-8 flex items-center gap-2 bg-zinc-900/80 border border-zinc-800 px-4 py-2 rounded-full backdrop-blur-sm text-sm text-zinc-400 tracking-wide transition-all duration-300 animate-pulse group-hover/hero:opacity-40">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6399bb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
          <span>Roll over to play snippet</span>
        </div>
      </div>

    </main>

    <!-- Hidden HTML5 Audio Element -->
    <audio id="audio-preview" src="/common-ground-sample.m4a" preload="auto" loop></audio>

    <!-- Custom CSS Animation Injection -->
    <style is:global>
      @keyframes record-spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .spinning {
        animation: record-spin 3.5s linear infinite !important;
      }
    </style>

    <!-- Original Working Hover Script Linked to the Container -->
    <script>
      // We bind to the full container so the hover isn't lost if the mouse shifts slightly
      const container = document.getElementById('interactive-container');
      const record = document.getElementById('vinyl-record');
      const audio = document.getElementById('audio-preview') as HTMLAudioElement;

      if (container && record && audio) {
        // Trigger Play and Spin on Hover Enter
        container.addEventListener('mouseenter', () => {
          audio.play().catch(err => console.log("Audio playback managed:", err));
          record.classList.add('spinning');
        });

        // Trigger Pause and Stop Spin on Hover Leave
        container.addEventListener('mouseleave', () => {
          audio.pause();
          record.classList.remove('spinning');
        });
      }
    </script>
  </body>
</html>